# Project-K Environment Variables
# Copy this file to .env and add your actual values

# OpenAI API Key - Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here

# Optional: Flask secret key for session management
SECRET_KEY=your-secret-key-for-sessions

# SOVEREIGN ENGINE CONFIGURATION
# Set your device hostname or a unique ID to enable Sovereign Mode
SOVEREIGN_HARDWARE_ID=adity-pc
SECRET_OWNER_KEY=KALI-XXXX-XXXX
